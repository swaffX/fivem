ensure qb-scrapyard

## Standalone Resources
ensure ox_lib
ensure progressbar
ensure screenshot-basic

## Custom Resources
ensure [alan]
ensure [meslek]
ensure [standalone]

## Server Convars
sv_scriptHookAllowed 0
sv_endpointprivacy true
sv_enableNetworkedPhoneExplosions false
sv_enableNetworkedSounds false

## Rcon Password (güvenli bir şifre belirleyin)
rcon_password "BURAYA_GUCLU_SIFRE"

## Server Info
sv_master1 ""
sv_lan false
