# FiveM Server - Git Ignore

# Cache dosyaları
data/cache/
**/cache/
**/.replxx_history

# Log dosyaları
*.log
logs/

# Veritabanı yedekleri
*.sql.bak
*.db.bak

# Geçici dosyaları
*.tmp
*.temp
*~

# Windows dosyaları
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# macOS dosyaları
.DS_Store
.AppleDouble
.LSOverride

# IDE dosyaları
.vscode/
.idea/
*.swp
*.swo
*~

# Node modules (eğer varsa)
node_modules/
package-lock.json

# Artifacts (FiveM binary dosyaları - VPS'de indirilecek)
artifacts/*.exe
artifacts/*.dll
artifacts/*.so
artifacts/*.dylib

# Sertifika ve key dosyaları (güvenlik)
*.key
*.crt
*.pem
*.p12

# Oyuncu verileri (VPS'de oluşturulacak)
data/resources/[qb]/qb-core/server/player.lua.bak
txData/
txAdmin/

# Stream cache dosyaları
**/stream_cache/

# Büyük dosyalar
*.zip
*.rar
*.7z
*.tar.gz

# Backup dosyaları
*.bak
*.backup
*.old

# Lua compiled dosyaları
*.luac

# FiveM server cache
citizen/

# Private config dosyaları (VPS'de düzenlenecek)
# server.cfg dosyası GitHub'da var, VPS'de düzenlenecek
# server.cfg.bkp ve diğer yedekler ignore edilecek
data/server.cfg.bkp
data/*.bkp

# Hassas bilgiler içeren dosyalar
**/admins.json
**/playersDB.json

# Büyük veritabanı dosyası (VPS'e ayrıca yüklenecek)
temelpaket.sql

# Test dosyaları
test/
tests/
*.test.lua

# Geliştirme dosyaları
dev/
development/

# Yedek SQL dosyaları (sadece gerekli olanları tuttuk)
# data/*.sql dosyaları zaten temizlendi
